# Nginx configuration for AI Token Dashboard
# Place this in /etc/nginx/sites-available/ai-token-dashboard

server {
    listen 80;
    server_name your-domain.com;  # Change to your domain

    # API routes -> Golang proxy (port 8080)
    location /api/v1/ {
        # Strip /api prefix - Golang expects /v1/...
        rewrite ^/api(/v1/.*)$ $1 break;

        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # SSE streaming support
        proxy_set_header Connection '';
        proxy_buffering off;
        proxy_cache off;
        chunked_transfer_encoding on;

        # Long timeout for AI responses
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    # All other routes -> Laravel (PHP-FPM)
    location / {
        root /var/www/ai-token-dashboard/public;
        index index.php;
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        root /var/www/ai-token-dashboard/public;
        fastcgi_pass unix:/var/run/php/php8.1-fpm.sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
    }

    location ~ /\.ht {
        deny all;
    }
}
